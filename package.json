{
  "name": "@haseeb-xd/havn",
  "version": "1.0.1",
  "description": "Local development dashboard — see every running service at a glance",
  "bin": {
    "havn": "./bin/havn.js"
  },
  "main": "./src/server.js",
  "scripts": {
    "start": "node bin/havn.js start",
    "dev":   "node bin/havn.js start --no-open"
  },
  "dependencies": {
    "express":   "^4.18.2",
    "ws":        "^8.14.2",
    "commander": "^11.1.0",
    "open":      "^9.1.0",
    "chalk":     "^4.1.2"
  },
  "files": [
    "bin/",
    "src/",
    "public/"
  ],
  "keywords": [
    "havn", "developer", "dashboard", "localhost",
    "devtools", "ports", "services", "monitor"
  ],
  "license": "MIT",
  "author": "Haseeb Ansari",
  "repository": {
    "type": "git",
    "url": "https://github.com/haseeb-xd/havn"
  },
  "homepage": "https://github.com/haseeb-xd/havn#readme",
  "engines": { "node": ">=16.0.0" }
}
